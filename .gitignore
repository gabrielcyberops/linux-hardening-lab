# ==============================================================================
# Linux Hardening Lab - Git Ignore Configuration
# ==============================================================================

# SISTEMA OPERATIVO Y ENTORNOS DE DESARROLLO
.DS_Store
Thumbs.db
.vscode/
*~
*.swp
tempCodeRunnerFile.*

# ARCHIVOS TEMPORALES Y RESPALDOS
*.tmp
*.bak
*.old
*.backup

# ENTORNOS VIRTUALES Y CACHE DE AUTOMATIZACIÓN
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/

# CREDENCIALES, LLAVES Y ARCHIVOS DE ENTORNO
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.pem
*.key
.env
.envrc

# REGISTROS DE SISTEMA Y REPORTE DE AUDITORÍA LOCAL
*.log
logs/
audit-output/
scan-results/
security-reports/

# ARCHIVOS COMPRIMIDOS
*.zip
*.tar
*.gz
*.7z